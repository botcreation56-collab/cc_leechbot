# ================================================================
#  .env.example  —  Copy to .env and fill in your values
#  DO NOT commit the real .env file to GitHub!
# ================================================================


# ─── REQUIRED ────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:ABCDefGhIjKlmNopQRsTuVWxYz

# Your Telegram user ID (get it by messaging @userinfobot)
# Multiple admins: comma-separated
ADMIN_IDS=123456789,987654321

# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true

# Your VPS domain (used for stream links etc.)
DOMAIN=yourdomain.com

# Environment — set to "production" on VPS
ENVIRONMENT=production


# ─── SECURITY (REQUIRED IN PRODUCTION) ───────────────────────────

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-here


# ─── PYROGRAM (OPTIONAL – needed only for uploads > 2GB) ─────────

# Get from https://my.telegram.org
API_ID=
API_HASH=

# Pyrogram session string (generate with pyrogram)
USERBOT_SESSION=


# ─── CHANNELS (OPTIONAL – can be set from /admin panel instead) ──

# Dump channel ID (negative number, e.g. -1001234567890)
DUMP_CHANNEL_ID=
STORAGE_CHANNEL_ID=
LOG_CHANNEL_ID=

# Force-subscribe channels (comma-separated channel IDs, optional)
FORCE_SUB_CHANNELS=


# ─── SERVER ──────────────────────────────────────────────────────

PORT=8080
WEB_HOST=0.0.0.0
WEB_PORT=8080


# ─── OPTIONAL OVERRIDES (defaults are fine for most setups) ──────

MONGODB_DB=filebot_production
TEMP_DIR=/tmp/filebot
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

BOT_USERNAME=your_bot_username
BOT_LINK=https://t.me/your_bot_username
